{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com/v1",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "languages": ["en", "zh"]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "reddit": {
      "enabled": true,
      "fetch_comments": 5,
      "subreddits": [
        { "subreddit": "MachineLearning", "sort": "hot", "fetch_limit": 15, "min_score": 50 },
        { "subreddit": "LocalLLaMA", "sort": "hot", "fetch_limit": 15, "min_score": 30 },
        { "subreddit": "semiconductor", "sort": "hot", "fetch_limit": 10, "min_score": 20 },
        { "subreddit": "robotics", "sort": "hot", "fetch_limit": 10, "min_score": 20 },
        { "subreddit": "energy", "sort": "hot", "fetch_limit": 15, "min_score": 20 },
        { "subreddit": "oilandgasworkers", "sort": "hot", "fetch_limit": 10, "min_score": 10 },
        { "subreddit": "nuclear", "sort": "hot", "fetch_limit": 10, "min_score": 10 },
        { "subreddit": "economics", "sort": "hot", "fetch_limit": 15, "min_score": 30 },
        { "subreddit": "geopolitics", "sort": "hot", "fetch_limit": 15, "min_score": 30 },
        { "subreddit": "wallstreetbets", "sort": "hot", "fetch_limit": 10, "min_score": 100 },
        { "subreddit": "gamedev", "sort": "hot", "fetch_limit": 15, "min_score": 30 },
        { "subreddit": "Games", "sort": "hot", "fetch_limit": 15, "min_score": 50 },
        { "subreddit": "pcgaming", "sort": "hot", "fetch_limit": 10, "min_score": 30 }
      ]
    },
    "rss": [
      {
        "name": "SemiAnalysis",
        "url": "https://www.semianalysis.com/feed",
        "enabled": true,
        "category": "tech-semi"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "tech-general"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "tech-general"
      },
      {
        "name": "TrendForce News",
        "url": "https://www.trendforce.com/news/feed",
        "enabled": true,
        "category": "tech-semi"
      },
      {
        "name": "MIT Technology Review",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "tech-general"
      },
      {
        "name": "S&P Global Energy - Oil",
        "url": "https://www.spglobal.com/commodityinsights/en/rss/oil",
        "enabled": true,
        "category": "energy-oil"
      },
      {
        "name": "S&P Global Energy - Electric Power",
        "url": "https://www.spglobal.com/commodityinsights/en/rss/electric-power",
        "enabled": true,
        "category": "energy-power"
      },
      {
        "name": "S&P Global Energy - Natural Gas",
        "url": "https://www.spglobal.com/commodityinsights/en/rss/natural-gas",
        "enabled": true,
        "category": "energy-gas"
      },
      {
        "name": "Utility Dive",
        "url": "https://www.utilitydive.com/feeds/news/",
        "enabled": true,
        "category": "energy-power"
      },
      {
        "name": "Latitude Media (Canary Media)",
        "url": "https://www.canarymedia.com/feed",
        "enabled": true,
        "category": "energy-power"
      },
      {
        "name": "Energy Intelligence",
        "url": "https://www.energyintel.com/rss-feed.rss",
        "enabled": true,
        "category": "energy-oil"
      },
      {
        "name": "Reuters Commodities",
        "url": "https://www.reuters.com/arc/outboundfeeds/v3/all/section/commodities/?outputType=xml",
        "enabled": true,
        "category": "macro-commodity"
      },
      {
        "name": "Reuters Markets",
        "url": "https://www.reuters.com/arc/outboundfeeds/v3/all/section/markets/?outputType=xml",
        "enabled": true,
        "category": "macro-markets"
      },
      {
        "name": "GamesIndustry.biz",
        "url": "https://www.gamesindustry.biz/feed",
        "enabled": true,
        "category": "gaming-biz"
      },
      {
        "name": "Game Developer (Gamasutra)",
        "url": "https://www.gamedeveloper.com/rss.xml",
        "enabled": true,
        "category": "gaming-dev"
      },
      {
        "name": "4Gamer.net",
        "url": "https://www.4gamer.net/rss/index.xml",
        "enabled": true,
        "category": "gaming-jp"
      },
      {
        "name": "Famitsu",
        "url": "https://www.famitsu.com/feed/",
        "enabled": true,
        "category": "gaming-jp"
      },
      {
        "name": "PC Gamer",
        "url": "https://www.pcgamer.com/rss/",
        "enabled": true,
        "category": "gaming-pc"
      },
      {
        "name": "SEC EDGAR - APP (AppLovin)",
        "url": "https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=0001498148&type=&dateb=&owner=include&count=10&search_text=&output=atom",
        "enabled": true,
        "category": "tracker"
      },
      {
        "name": "SEC EDGAR - BE (Bloom Energy)",
        "url": "https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=0001664703&type=&dateb=&owner=include&count=10&search_text=&output=atom",
        "enabled": true,
        "category": "tracker"
      },
      {
        "name": "SEC EDGAR - GEV (GE Vernova)",
        "url": "https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=0001974446&type=&dateb=&owner=include&count=10&search_text=&output=atom",
        "enabled": true,
        "category": "tracker"
      }
    ],
    "github": [
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-sdk-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "deepseek-ai",
        "repo": "DeepSeek-V3",
        "enabled": true
      }
    ]
  },
  "groups": [
    {
      "name": "Tech",
      "categories": ["hackernews", "tech-semi", "tech-general"],
      "scoring": { "enabled": true, "threshold": 6.0 }
    },
    {
      "name": "Energy",
      "categories": ["energy-oil", "energy-power", "energy-gas"],
      "scoring": { "enabled": true, "threshold": 5.0 }
    },
    {
      "name": "Macro",
      "categories": ["macro-commodity", "macro-markets"],
      "scoring": { "enabled": true, "threshold": 6.0 }
    },
    {
      "name": "Gaming",
      "categories": ["gaming-biz", "gaming-dev", "gaming-jp", "gaming-pc"],
      "scoring": { "enabled": true, "threshold": 5.0 }
    },
    {
      "name": "Tracker",
      "categories": ["tracker"],
      "scoring": { "enabled": false }
    }
  ],
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "platform": "generic",
    "layout": "markdown"
  }
}
